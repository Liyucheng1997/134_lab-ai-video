# 复制为 .env 并填入你的密钥
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
# 可选覆盖项：
# DEEPSEEK_MODEL=deepseek-chat
# WHISPER_MODEL=small            # 或 large-v3-turbo（质量更好，首次需联网下载）
# WHISPER_DEVICE=cuda
# TTS_VOICE=冷峻哲思             # 沉稳男声 / 低沉磁性 / 深夜电台 / 冷峻哲思 等
# TTS_GAP_MIN=0.08              # 段间最短停顿（秒）
# TTS_GAP_MAX=0.45             # 段间最长停顿（秒，去掉原视频大段空白）
# 声音克隆（可选）：指定一段参考人声即可用它配音
# TTS_REF_AUDIO=F:\path\to\voice.wav
# TTS_REF_TEXT=参考音频对应的文字（留空会自动识别，较慢）
# SUB_FONT=Microsoft YaHei
# SUB_FONTSIZE=54
# B 站自动投稿：先运行 python bili_login.py 扫码生成 cookie
# BILIBILI_COOKIE_FILE=F:\我的编程项目\123_AI视频自动化\work\bilibili.cookie.json
# BILIBILI_TID=228                 # 228=知识/社科·法律·心理
# BILIBILI_COPYRIGHT=1             # 1=自制；2=转载
# BILIBILI_UPLOAD_LINE=bda2        # 上传线路：bda2 / bda / tx；不建议 AUTO，容易选到不稳定线路
# BILIBILI_UPLOAD_TIMEOUT=60       # 单条线路最多等待秒数，超时自动换线
