# 复制为 .env 并填入你的密钥
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
# 可选覆盖项：
# DEEPSEEK_MODEL=deepseek-chat
# WHISPER_MODEL=small            # 或 large-v3-turbo（质量更好，首次需联网下载）
# WHISPER_DEVICE=cuda
# ---- TTS 配音引擎（界面可切换：qwen3 / f5 / azure / cosyvoice）----
# TTS_ENGINE=gemini              # 默认引擎；界面选择会临时覆盖
# TTS_VOICE=Umbriel·从容随和     # 默认音色（取决于引擎）
# TTS_SPEED=1.15                 # 语速倍率（界面滑块 0.7~1.3）
# TTS_GAP_MIN=0.08              # 段间最短停顿（秒）
# TTS_GAP_MAX=0.45             # 段间最长停顿（秒，去掉原视频大段空白）

# Qwen3-TTS（本地·稳定）：speaker = ryan / aiden / dylan / eric / serena 等
# QWEN_TTS_MODEL=Qwen/Qwen3-TTS-12Hz-1.7B-CustomVoice
# QWEN_TTS_DEVICE=cuda:0
# QWEN_TTS_ATTENTION=sdpa        # Windows 下默认用 PyTorch SDPA；flash_attention_2 需另装 flash-attn
# QWEN_TTS_MAX_CHARS=280         # 每个连续配音文本块的最大中文字符数
# QWEN_TTS_BATCH_SIZE=2          # 每次送入 Qwen 的文本块数量，显存足够可调到 3

# F5-TTS（本地·音色克隆）：内置 沉稳男声/温柔女声/浑厚男声；可自定义参考音频克隆
# TTS_REF_AUDIO=                 # 自定义参考音频 wav/flac 路径（留空用内置音色）
# TTS_REF_TEXT=                  # 参考音频对应文字

# Azure TTS（云端·最自然）：到 portal.azure.com 开「语音服务」拿 KEY 与区域
# AZURE_SPEECH_KEY=
# AZURE_SPEECH_REGION=eastus
# AZURE_TTS_STYLE=               # 朗读风格，如 calm / narration-relaxed / gentle / sad（留空为默认）
# AZURE_TTS_STYLE_DEGREE=1       # 风格强度 0.01~2

# CosyVoice2（阿里·开源本地·情感指令）：需 git clone CosyVoice 并下载 CosyVoice2-0.5B
# COSYVOICE_REPO_DIR=tools/CosyVoice
# COSYVOICE_MODEL_DIR=models/cosyvoice/CosyVoice2-0.5B
# COSYVOICE_REF_AUDIO=           # 克隆音色的参考音频（留空用仓库自带 asset/zero_shot_prompt.wav）
# COSYVOICE_REF_TEXT=
# COSYVOICE_INSTRUCT=用温暖、沉稳、富有疗愈感的语气，像一位睿智的引路人娓娓道来。

# Gemini TTS（云端·可控情感）：到 aistudio.google.com/apikey 申请 key
# GEMINI_API_KEY=
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com   # 国内可填反代/中转地址（到 /v1beta 上一级）
# GEMINI_TTS_MODEL=gemini-2.5-pro-preview-tts   # Pro 更自然(播客/有声书)；flash 更快更省：gemini-2.5-flash-preview-tts
# GEMINI_TTS_STYLE=用温暖、沉稳、富有疗愈感的语气朗读   # 自然语言风格引导；留空则只按原文朗读
# GEMINI_TTS_MAX_CHARS=800       # 每个 Gemini 请求的最大中文字符数；越大音色越连贯，字幕逐句估时会略粗
# GEMINI_TTS_TARGET_RMS=0.075    # 分块响度归一目标；通常不用改
# GEMINI_TTS_TIMEOUT=180         # 单个 Gemini TTS 请求超时秒数；分块越大应越高

# SUB_FONT=Microsoft YaHei
# SUB_FONTSIZE=54
# BILIBILI_TID=228                 # 228=知识/社科·法律·心理
# BILIBILI_COPYRIGHT=1             # 1=自制；2=转载
