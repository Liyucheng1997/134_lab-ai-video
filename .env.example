# 复制为 .env 并填入你的密钥
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
# 可选覆盖项：
# DEEPSEEK_MODEL=deepseek-chat
# WHISPER_MODEL=small            # 或 large-v3-turbo（质量更好，首次需联网下载）
# WHISPER_DEVICE=cuda
# ---- TTS 配音引擎：仅 F5-TTS ----
# TTS_ENGINE=f5
# TTS_VOICE=人工老龙凤            # 默认音色
# TTS_SPEED=1.00                 # 后期语速倍率；F5 推理保持原速，最终音轨用该倍率调速
# TTS_GAP_MIN=0.08              # 段间最短停顿（秒）
# TTS_GAP_MAX=0.45             # 段间最长停顿（秒，去掉原视频大段空白）

# F5-TTS（本地·音色克隆）：内置音色 + 自定义参考音频克隆
# TTS_REF_AUDIO=                 # 自定义参考音频 wav/flac 路径（留空用内置音色）
# TTS_REF_TEXT=                  # 参考音频对应文字
# F5_TTS_PARALLEL=2              # F5 字幕段并发数；16GB 显存建议先用 2，稳定后可试 3/4

# SUB_FONT=Microsoft YaHei
# SUB_FONTSIZE=54
# BILIBILI_TID=228                 # 228=知识/社科·法律·心理
# BILIBILI_COPYRIGHT=1             # 1=自制；2=转载
