# 复制为 .env 并填入你的密钥
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
# 可选覆盖项：
# DEEPSEEK_MODEL=deepseek-chat
# WHISPER_MODEL=small            # 或 large-v3-turbo（质量更好，首次需联网下载）
# WHISPER_DEVICE=cuda
# TTS_VOICE=温柔女声             # 沉稳男声 / 温柔女声 / 浑厚男声
# TTS_GAP_MIN=0.08              # 段间最短停顿（秒）
# TTS_GAP_MAX=0.45             # 段间最长停顿（秒，去掉原视频大段空白）
# 声音克隆（可选）：指定一段参考人声即可用它配音
# TTS_REF_AUDIO=F:\path\to\voice.wav
# TTS_REF_TEXT=参考音频对应的文字（留空会自动识别，较慢）
# SUB_FONT=Microsoft YaHei
# SUB_FONTSIZE=54
